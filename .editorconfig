# Root editorconfig. Per-project .editorconfig files (e.g. KeepPressing.Core) inherit this and add
# project-specific rules (such as Core's CA2007=error).
root = true

[*]
charset = utf-8
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

[*.{csproj,props,targets,slnx}]
indent_size = 2

[*.{cs,xaml}]
indent_size = 4

[*.cs]
csharp_style_namespace_declarations = file_scoped:suggestion
dotnet_sort_system_directives_first = true

# Exclude generated code from style/analysis (WinUI XAML *.g.cs, CsWin32, AssemblyInfo).
[{**/obj/**/*,**/*.g.cs,**/*.g.i.cs,**/*.Designer.cs}]
generated_code = true
dotnet_analyzer_diagnostic.severity = none
