<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KeepPressing.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KeepPressing"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PreviewKeyDown="OnPagePreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 固定アクションヘッダー（最上部・スクロールしない。実行中も操作可） -->
        <Border
            Grid.Row="0"
            Padding="24,12"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel
                MaxWidth="640"
                HorizontalAlignment="Stretch"
                Spacing="8">
                <Button
                    AutomationProperties.AutomationId="ToggleButton"
                    MinHeight="48"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.ToggleCommand}"
                    Content="{x:Bind ViewModel.ToggleButtonLabel, Mode=OneWay}"
                    FontSize="16"
                    Style="{StaticResource AccentButtonStyle}" />

                <!-- 開始/停止ホットキー：ボタンと直結する設定なのでヘッダーに常時表示（実行中は他設定同様グレーアウト） -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="開始/停止ホットキー" />
                    <ComboBox
                        AutomationProperties.AutomationId="HotkeySelector"
                        AutomationProperties.Name="開始停止ホットキー"
                        MinWidth="90"
                        IsEnabled="{x:Bind ViewModel.IsNotRunning, Mode=OneWay}"
                        SelectedIndex="{x:Bind ViewModel.HotkeyIndex, Mode=TwoWay}">
                        <x:String>F5</x:String>
                        <x:String>F6</x:String>
                        <x:String>F7</x:String>
                        <x:String>F9</x:String>
                        <x:String>F10</x:String>
                    </ComboBox>
                </StackPanel>

                <TextBlock
                    AutomationProperties.AutomationId="StatusText"
                    HorizontalAlignment="Center"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <InfoBar
                    AutomationProperties.AutomationId="ErrorBar"
                    CloseButtonClick="OnErrorBarCloseClicked"
                    IsClosable="True"
                    IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                    Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Severity="Error" />
            </StackPanel>
        </Border>

        <!-- スクロール設定 -->
        <ScrollViewer Grid.Row="1" Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="640"
                HorizontalAlignment="Stretch"
                Spacing="16">

                <!-- 設定ブロック（実行中は一括で無効化）。StackPanel は Control でないため ContentControl で包む -->
                <ContentControl
                    HorizontalContentAlignment="Stretch"
                    IsEnabled="{x:Bind ViewModel.IsNotRunning, Mode=OneWay}"
                    IsTabStop="False">
                    <StackPanel Spacing="12">

                        <!-- 対象（マウス / キーボード）をタブ切り替え -->
                        <SelectorBar
                            x:Name="TargetSelector"
                            AutomationProperties.AutomationId="TargetKind"
                            AutomationProperties.Name="連打の対象"
                            HorizontalAlignment="Center"
                            SelectionChanged="OnTargetSelectionChanged">
                            <SelectorBarItem AutomationProperties.Name="マウス" Text="マウス">
                                <SelectorBarItem.Icon>
                                    <FontIcon Glyph="&#xE962;" />
                                </SelectorBarItem.Icon>
                            </SelectorBarItem>
                            <SelectorBarItem AutomationProperties.Name="キーボード" Text="キーボード">
                                <SelectorBarItem.Icon>
                                    <FontIcon Glyph="&#xE765;" />
                                </SelectorBarItem.Icon>
                            </SelectorBarItem>
                        </SelectorBar>

                        <!-- マウス設定 -->
                        <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.IsMouseTarget, Mode=OneWay}">
                            <controls:SettingsExpander
                                Description="ボタン・クリック位置の設定"
                                Header="マウス設定"
                                IsExpanded="True">
                                <controls:SettingsExpander.HeaderIcon>
                                    <FontIcon Glyph="&#xE962;" />
                                </controls:SettingsExpander.HeaderIcon>
                                <controls:SettingsExpander.Items>
                                    <controls:SettingsCard Header="ボタン">
                                        <ComboBox
                                            AutomationProperties.AutomationId="MouseButtonSelector"
                                            AutomationProperties.Name="マウスボタン"
                                            MinWidth="160"
                                            SelectedIndex="{x:Bind ViewModel.MouseButtonIndex, Mode=TwoWay}">
                                            <x:String>左クリック</x:String>
                                            <x:String>右クリック</x:String>
                                            <x:String>中クリック</x:String>
                                        </ComboBox>
                                    </controls:SettingsCard>

                                    <controls:SettingsCard Header="クリック位置">
                                        <ToggleSwitch
                                            AutomationProperties.AutomationId="UseFixedPosition"
                                            AutomationProperties.Name="クリック位置"
                                            IsOn="{x:Bind ViewModel.UseFixedPosition, Mode=TwoWay}"
                                            OffContent="現在のカーソル位置"
                                            OnContent="固定座標" />
                                    </controls:SettingsCard>

                                    <controls:SettingsCard Header="固定座標" Visibility="{x:Bind ViewModel.UseFixedPosition, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <NumberBox
                                                AutomationProperties.AutomationId="FixedX"
                                                AutomationProperties.Name="X 座標"
                                                Header="X"
                                                MinWidth="100"
                                                SmallChange="1"
                                                SpinButtonPlacementMode="Compact"
                                                Value="{x:Bind ViewModel.FixedX, Mode=TwoWay}" />
                                            <NumberBox
                                                AutomationProperties.AutomationId="FixedY"
                                                AutomationProperties.Name="Y 座標"
                                                Header="Y"
                                                MinWidth="100"
                                                SmallChange="1"
                                                SpinButtonPlacementMode="Compact"
                                                Value="{x:Bind ViewModel.FixedY, Mode=TwoWay}" />
                                            <Button
                                                AutomationProperties.AutomationId="CapturePosition"
                                                VerticalAlignment="Bottom"
                                                Command="{x:Bind ViewModel.CapturePositionCommand}"
                                                Content="画面から取得" />
                                        </StackPanel>
                                    </controls:SettingsCard>
                                </controls:SettingsExpander.Items>
                            </controls:SettingsExpander>

                            <InfoBar
                                AutomationProperties.AutomationId="CaptureInfo"
                                Title="座標キャプチャ中"
                                IsClosable="False"
                                IsOpen="{x:Bind ViewModel.IsCapturingPosition, Mode=OneWay}"
                                Message="目標へマウスを移動し、F8 で確定 / Esc で取消します（この間 F8 と Esc は本アプリが専有します）。"
                                Severity="Informational">
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal" Spacing="12">
                                    <TextBlock
                                        AutomationProperties.AutomationId="LivePosition"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.LivePositionText, Mode=OneWay}" />
                                    <Button
                                        AutomationProperties.AutomationId="CancelCapture"
                                        Command="{x:Bind ViewModel.CapturePositionCancelCommand}"
                                        Content="キャンセル (Esc)" />
                                </StackPanel>
                            </InfoBar>
                        </StackPanel>

                        <!-- キーボード設定 -->
                        <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.IsKeyboardTarget, Mode=OneWay}">
                            <controls:SettingsCard Description="連打するキーを割り当てます" Header="キー">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE765;" />
                                </controls:SettingsCard.HeaderIcon>
                                <StackPanel
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="12">
                                    <TextBlock
                                        AutomationProperties.AutomationId="KeyDisplay"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.KeyDisplay, Mode=OneWay}" />
                                    <ToggleButton
                                        AutomationProperties.AutomationId="ArmKeyCapture"
                                        AutomationProperties.Name="キーを設定"
                                        Content="キーを設定"
                                        IsChecked="{x:Bind ViewModel.IsKeyCaptureArmed, Mode=TwoWay}" />
                                </StackPanel>
                            </controls:SettingsCard>
                            <TextBlock
                                Margin="4,0,0,0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="このまま割り当てたいキーを押してください。"
                                Visibility="{x:Bind ViewModel.IsKeyCaptureArmed, Mode=OneWay}" />
                        </StackPanel>

                        <!-- 動作 -->
                        <controls:SettingsCard Description="連打 または 長押し" Header="動作">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8EE;" />
                            </controls:SettingsCard.HeaderIcon>
                            <ComboBox
                                AutomationProperties.AutomationId="ModeSelector"
                                AutomationProperties.Name="動作モード"
                                MinWidth="160"
                                SelectedIndex="{x:Bind ViewModel.ModeIndex, Mode=TwoWay}">
                                <x:String>連打</x:String>
                                <x:String>長押し</x:String>
                            </ComboBox>
                        </controls:SettingsCard>

                        <controls:SettingsCard Header="間隔 (ms)" Visibility="{x:Bind ViewModel.IsRepeatMode, Mode=OneWay}">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE916;" />
                            </controls:SettingsCard.HeaderIcon>
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="12">
                                <NumberBox
                                    AutomationProperties.AutomationId="IntervalMs"
                                    AutomationProperties.Name="連打間隔ミリ秒"
                                    Maximum="10000"
                                    MinWidth="140"
                                    Minimum="10"
                                    SmallChange="10"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.IntervalMs, Mode=TwoWay}" />
                                <TextBlock
                                    AutomationProperties.AutomationId="CpsText"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.CpsText, Mode=OneWay}" />
                            </StackPanel>
                        </controls:SettingsCard>
                    </StackPanel>
                </ContentControl>

                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="ヒント: 開始/停止はホットキーが便利です。実行中は Esc連打でも緊急停止できます。「現在のカーソル位置」モードでこのボタンから開始すると、自アプリの上を連打することになります。"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
