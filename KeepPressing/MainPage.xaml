<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KeepPressing.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KeepPressing"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:KeepPressing.ViewModels"
    mc:Ignorable="d"
    PreviewKeyDown="OnPagePreviewKeyDown">

    <!--
        Layout: a fixed command/status zone (Row 0, usable while running) over a
        scrollable settings zone (Row 1). No opaque background is set on any layout
        panel so the window's Mica material shows through; only SettingsCards form
        intentional surfaces. Sizes/spacing/glyphs come from the design tokens in
        App.xaml; colors use Fluent ThemeResource brushes.
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Fixed command/status zone: stays at the top, doesn't scroll, usable while running. -->
        <Border
            Grid.Row="0"
            Padding="{StaticResource CommandZonePadding}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel
                MaxWidth="{StaticResource ContentMaxWidth}"
                HorizontalAlignment="Stretch"
                Spacing="{StaticResource SpacingMedium}">
                <Button
                    AutomationProperties.AutomationId="ToggleButton"
                    MinHeight="{StaticResource PrimaryButtonMinHeight}"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.ToggleCommand}"
                    Content="{x:Bind ViewModel.ToggleButtonLabel, Mode=OneWay}"
                    FontSize="{StaticResource PrimaryButtonFontSize}"
                    Style="{StaticResource AccentButtonStyle}" />

                <!-- Status row: a spinning ProgressRing + success dot signal "running" alongside the status text. -->
                <StackPanel
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="{StaticResource SpacingSmall}">
                    <ProgressRing
                        Width="{StaticResource StatusIndicatorSize}"
                        Height="{StaticResource StatusIndicatorSize}"
                        VerticalAlignment="Center"
                        IsActive="{x:Bind ViewModel.IsRunning, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay}" />
                    <InfoBadge
                        VerticalAlignment="Center"
                        Style="{StaticResource SuccessDotInfoBadgeStyle}"
                        Visibility="{x:Bind ViewModel.IsRunning, Mode=OneWay}" />
                    <TextBlock
                        AutomationProperties.AutomationId="StatusText"
                        VerticalAlignment="Center"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>

                <!-- Start/stop hotkey: tied to the button, so always shown in the header (greyed out while running). -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="{StaticResource SpacingSmall}">
                    <TextBlock
                        x:Uid="HotkeyLabel"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ComboBox
                        x:Uid="HotkeySelector"
                        AutomationProperties.AutomationId="HotkeySelector"
                        MinWidth="{StaticResource HotkeyComboBoxMinWidth}"
                        DisplayMemberPath="DisplayKey"
                        IsEnabled="{x:Bind ViewModel.IsNotRunning, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.HotkeyChoices}"
                        SelectedItem="{x:Bind ViewModel.SelectedHotkey, Mode=TwoWay}" />
                </StackPanel>

                <InfoBar
                    AutomationProperties.AutomationId="ErrorBar"
                    CloseButtonClick="OnErrorBarCloseClicked"
                    IsClosable="True"
                    IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                    Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Severity="Error" />
            </StackPanel>
        </Border>

        <!-- Scrollable settings -->
        <ScrollViewer Grid.Row="1" Padding="{StaticResource SettingsZonePadding}" VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="{StaticResource ContentMaxWidth}"
                HorizontalAlignment="Stretch"
                Spacing="{StaticResource SpacingLarge}">

                <!-- Settings block, disabled as a whole while running. Wrapped in a ContentControl since StackPanel isn't a Control. -->
                <ContentControl
                    HorizontalContentAlignment="Stretch"
                    IsEnabled="{x:Bind ViewModel.IsNotRunning, Mode=OneWay}"
                    IsTabStop="False">
                    <StackPanel Spacing="{StaticResource SpacingLarge}">

                        <!-- Target tabs (mouse / keyboard) -->
                        <SelectorBar
                            x:Name="TargetSelector"
                            x:Uid="TargetSelector"
                            AutomationProperties.AutomationId="TargetKind"
                            HorizontalAlignment="Center"
                            SelectionChanged="OnTargetSelectionChanged">
                            <SelectorBarItem x:Uid="TargetMouse" Tag="{x:Bind vm:TargetKind.Mouse}">
                                <SelectorBarItem.Icon>
                                    <FontIcon Glyph="{StaticResource GlyphMouse}" />
                                </SelectorBarItem.Icon>
                            </SelectorBarItem>
                            <SelectorBarItem x:Uid="TargetKeyboard" Tag="{x:Bind vm:TargetKind.Keyboard}">
                                <SelectorBarItem.Icon>
                                    <FontIcon Glyph="{StaticResource GlyphKeyboard}" />
                                </SelectorBarItem.Icon>
                            </SelectorBarItem>
                        </SelectorBar>

                        <!-- Mouse settings group -->
                        <StackPanel Spacing="{StaticResource SpacingXSmall}" Visibility="{x:Bind ViewModel.IsMouseTarget, Mode=OneWay}">
                            <TextBlock x:Uid="MouseGroupHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />

                            <controls:SettingsCard x:Uid="MouseButtonCard">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="{StaticResource GlyphMouse}" />
                                </controls:SettingsCard.HeaderIcon>
                                <ComboBox
                                    x:Uid="MouseButtonSelector"
                                    AutomationProperties.AutomationId="MouseButtonSelector"
                                    MinWidth="{StaticResource ComboBoxMinWidth}"
                                    DisplayMemberPath="DisplayName"
                                    ItemsSource="{x:Bind ViewModel.MouseButtons}"
                                    SelectedItem="{x:Bind ViewModel.SelectedMouseButton, Mode=TwoWay}" />
                            </controls:SettingsCard>

                            <controls:SettingsCard x:Uid="ClickPositionCard">
                                <ToggleSwitch
                                    x:Uid="UseFixedPosition"
                                    AutomationProperties.AutomationId="UseFixedPosition"
                                    IsOn="{x:Bind ViewModel.UseFixedPosition, Mode=TwoWay}" />
                            </controls:SettingsCard>

                            <controls:SettingsCard x:Uid="FixedPositionCard" Visibility="{x:Bind ViewModel.UseFixedPosition, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                    <NumberBox
                                        x:Uid="FixedX"
                                        AutomationProperties.AutomationId="FixedX"
                                        Header="X"
                                        MinWidth="{StaticResource CoordinateBoxMinWidth}"
                                        SmallChange="1"
                                        SpinButtonPlacementMode="Compact"
                                        Value="{x:Bind ViewModel.FixedX, Mode=TwoWay}" />
                                    <NumberBox
                                        x:Uid="FixedY"
                                        AutomationProperties.AutomationId="FixedY"
                                        Header="Y"
                                        MinWidth="{StaticResource CoordinateBoxMinWidth}"
                                        SmallChange="1"
                                        SpinButtonPlacementMode="Compact"
                                        Value="{x:Bind ViewModel.FixedY, Mode=TwoWay}" />
                                    <Button
                                        x:Uid="CapturePositionButton"
                                        AutomationProperties.AutomationId="CapturePosition"
                                        VerticalAlignment="Bottom"
                                        Command="{x:Bind ViewModel.CapturePositionCommand}" />
                                </StackPanel>
                            </controls:SettingsCard>

                            <InfoBar
                                x:Uid="CaptureInfo"
                                AutomationProperties.AutomationId="CaptureInfo"
                                IsClosable="False"
                                IsOpen="{x:Bind ViewModel.IsCapturingPosition, Mode=OneWay}"
                                Severity="Informational">
                                <StackPanel Margin="{StaticResource CaptureContentMargin}" Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}">
                                    <TextBlock
                                        AutomationProperties.AutomationId="LivePosition"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.LivePositionText, Mode=OneWay}" />
                                    <Button
                                        x:Uid="CancelCaptureButton"
                                        AutomationProperties.AutomationId="CancelCapture"
                                        Command="{x:Bind ViewModel.CapturePositionCancelCommand}" />
                                </StackPanel>
                            </InfoBar>
                        </StackPanel>

                        <!-- Keyboard settings group -->
                        <StackPanel Spacing="{StaticResource SpacingXSmall}" Visibility="{x:Bind ViewModel.IsKeyboardTarget, Mode=OneWay}">
                            <TextBlock x:Uid="KeyGroupHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />

                            <controls:SettingsCard x:Uid="KeyCard">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="{StaticResource GlyphKeyboard}" />
                                </controls:SettingsCard.HeaderIcon>
                                <StackPanel
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="{StaticResource SpacingMedium}">
                                    <TextBlock
                                        AutomationProperties.AutomationId="KeyDisplay"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.KeyDisplay, Mode=OneWay}" />
                                    <ToggleButton
                                        x:Uid="ArmKeyCapture"
                                        AutomationProperties.AutomationId="ArmKeyCapture"
                                        IsChecked="{x:Bind ViewModel.IsKeyCaptureArmed, Mode=TwoWay}" />
                                </StackPanel>
                            </controls:SettingsCard>
                            <TextBlock
                                x:Uid="KeyCaptureHint"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Visibility="{x:Bind ViewModel.IsKeyCaptureArmed, Mode=OneWay}" />
                        </StackPanel>

                        <!-- Action group -->
                        <StackPanel Spacing="{StaticResource SpacingXSmall}">
                            <TextBlock x:Uid="ActionGroupHeader" Style="{StaticResource BodyStrongTextBlockStyle}" />

                            <controls:SettingsCard x:Uid="ActionCard">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="{StaticResource GlyphAction}" />
                                </controls:SettingsCard.HeaderIcon>
                                <ComboBox
                                    x:Uid="ModeSelector"
                                    AutomationProperties.AutomationId="ModeSelector"
                                    MinWidth="{StaticResource ComboBoxMinWidth}"
                                    DisplayMemberPath="DisplayName"
                                    ItemsSource="{x:Bind ViewModel.Modes}"
                                    SelectedItem="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}" />
                            </controls:SettingsCard>

                            <controls:SettingsCard x:Uid="IntervalCard" Visibility="{x:Bind ViewModel.IsRepeatMode, Mode=OneWay}">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="{StaticResource GlyphInterval}" />
                                </controls:SettingsCard.HeaderIcon>
                                <StackPanel
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="{StaticResource SpacingMedium}">
                                    <NumberBox
                                        x:Uid="IntervalMs"
                                        AutomationProperties.AutomationId="IntervalMs"
                                        Maximum="{x:Bind vm:MainPageViewModel.IntervalMaxMs}"
                                        MinWidth="{StaticResource NumberBoxMinWidth}"
                                        Minimum="{x:Bind vm:MainPageViewModel.IntervalMinMs}"
                                        SmallChange="{x:Bind vm:MainPageViewModel.IntervalStepMs}"
                                        SpinButtonPlacementMode="Compact"
                                        Value="{x:Bind ViewModel.IntervalMs, Mode=TwoWay}" />
                                    <TextBlock
                                        AutomationProperties.AutomationId="CpsText"
                                        VerticalAlignment="Center"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind ViewModel.CpsText, Mode=OneWay}" />
                                </StackPanel>
                            </controls:SettingsCard>
                        </StackPanel>
                    </StackPanel>
                </ContentControl>

                <TextBlock
                    x:Uid="Hint"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
