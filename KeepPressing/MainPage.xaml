<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KeepPressing.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KeepPressing"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:KeepPressing.ViewModels"
    mc:Ignorable="d"
    PreviewKeyDown="OnPagePreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Fixed action header: stays at the top, doesn't scroll, usable while running. -->
        <Border
            Grid.Row="0"
            Padding="24,12"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel
                MaxWidth="640"
                HorizontalAlignment="Stretch"
                Spacing="8">
                <Button
                    AutomationProperties.AutomationId="ToggleButton"
                    MinHeight="48"
                    HorizontalAlignment="Stretch"
                    Command="{x:Bind ViewModel.ToggleCommand}"
                    Content="{x:Bind ViewModel.ToggleButtonLabel, Mode=OneWay}"
                    FontSize="16"
                    Style="{StaticResource AccentButtonStyle}" />

                <!-- Start/stop hotkey: tied to the button, so always shown in the header (greyed out while running). -->
                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <TextBlock
                        x:Uid="HotkeyLabel"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ComboBox
                        x:Uid="HotkeySelector"
                        AutomationProperties.AutomationId="HotkeySelector"
                        MinWidth="90"
                        DisplayMemberPath="DisplayKey"
                        IsEnabled="{x:Bind ViewModel.IsNotRunning, Mode=OneWay}"
                        ItemsSource="{x:Bind ViewModel.HotkeyChoices}"
                        SelectedItem="{x:Bind ViewModel.SelectedHotkey, Mode=TwoWay}" />
                </StackPanel>

                <TextBlock
                    AutomationProperties.AutomationId="StatusText"
                    HorizontalAlignment="Center"
                    Style="{StaticResource BodyStrongTextBlockStyle}"
                    Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
                <InfoBar
                    AutomationProperties.AutomationId="ErrorBar"
                    CloseButtonClick="OnErrorBarCloseClicked"
                    IsClosable="True"
                    IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                    Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                    Severity="Error" />
            </StackPanel>
        </Border>

        <!-- Scrollable settings -->
        <ScrollViewer Grid.Row="1" Padding="24,16,24,24" VerticalScrollBarVisibility="Auto">
            <StackPanel
                MaxWidth="640"
                HorizontalAlignment="Stretch"
                Spacing="16">

                <!-- Settings block, disabled as a whole while running. Wrapped in a ContentControl since StackPanel isn't a Control. -->
                <ContentControl
                    HorizontalContentAlignment="Stretch"
                    IsEnabled="{x:Bind ViewModel.IsNotRunning, Mode=OneWay}"
                    IsTabStop="False">
                    <StackPanel Spacing="12">

                        <!-- Target tabs (mouse / keyboard) -->
                        <SelectorBar
                            x:Name="TargetSelector"
                            x:Uid="TargetSelector"
                            AutomationProperties.AutomationId="TargetKind"
                            HorizontalAlignment="Center"
                            SelectionChanged="OnTargetSelectionChanged">
                            <SelectorBarItem x:Uid="TargetMouse" Tag="{x:Bind vm:TargetKind.Mouse}">
                                <SelectorBarItem.Icon>
                                    <FontIcon Glyph="&#xE962;" />
                                </SelectorBarItem.Icon>
                            </SelectorBarItem>
                            <SelectorBarItem x:Uid="TargetKeyboard" Tag="{x:Bind vm:TargetKind.Keyboard}">
                                <SelectorBarItem.Icon>
                                    <FontIcon Glyph="&#xE765;" />
                                </SelectorBarItem.Icon>
                            </SelectorBarItem>
                        </SelectorBar>

                        <!-- Mouse settings -->
                        <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.IsMouseTarget, Mode=OneWay}">
                            <controls:SettingsExpander
                                x:Uid="MouseSettings"
                                IsExpanded="True">
                                <controls:SettingsExpander.HeaderIcon>
                                    <FontIcon Glyph="&#xE962;" />
                                </controls:SettingsExpander.HeaderIcon>
                                <controls:SettingsExpander.Items>
                                    <controls:SettingsCard x:Uid="MouseButtonCard">
                                        <ComboBox
                                            x:Uid="MouseButtonSelector"
                                            AutomationProperties.AutomationId="MouseButtonSelector"
                                            MinWidth="160"
                                            DisplayMemberPath="DisplayName"
                                            ItemsSource="{x:Bind ViewModel.MouseButtons}"
                                            SelectedItem="{x:Bind ViewModel.SelectedMouseButton, Mode=TwoWay}" />
                                    </controls:SettingsCard>

                                    <controls:SettingsCard x:Uid="ClickPositionCard">
                                        <ToggleSwitch
                                            x:Uid="UseFixedPosition"
                                            AutomationProperties.AutomationId="UseFixedPosition"
                                            IsOn="{x:Bind ViewModel.UseFixedPosition, Mode=TwoWay}" />
                                    </controls:SettingsCard>

                                    <controls:SettingsCard x:Uid="FixedPositionCard" Visibility="{x:Bind ViewModel.UseFixedPosition, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <NumberBox
                                                x:Uid="FixedX"
                                                AutomationProperties.AutomationId="FixedX"
                                                Header="X"
                                                MinWidth="100"
                                                SmallChange="1"
                                                SpinButtonPlacementMode="Compact"
                                                Value="{x:Bind ViewModel.FixedX, Mode=TwoWay}" />
                                            <NumberBox
                                                x:Uid="FixedY"
                                                AutomationProperties.AutomationId="FixedY"
                                                Header="Y"
                                                MinWidth="100"
                                                SmallChange="1"
                                                SpinButtonPlacementMode="Compact"
                                                Value="{x:Bind ViewModel.FixedY, Mode=TwoWay}" />
                                            <Button
                                                x:Uid="CapturePositionButton"
                                                AutomationProperties.AutomationId="CapturePosition"
                                                VerticalAlignment="Bottom"
                                                Command="{x:Bind ViewModel.CapturePositionCommand}" />
                                        </StackPanel>
                                    </controls:SettingsCard>
                                </controls:SettingsExpander.Items>
                            </controls:SettingsExpander>

                            <InfoBar
                                x:Uid="CaptureInfo"
                                AutomationProperties.AutomationId="CaptureInfo"
                                IsClosable="False"
                                IsOpen="{x:Bind ViewModel.IsCapturingPosition, Mode=OneWay}"
                                Severity="Informational">
                                <StackPanel Margin="0,0,0,12" Orientation="Horizontal" Spacing="12">
                                    <TextBlock
                                        AutomationProperties.AutomationId="LivePosition"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.LivePositionText, Mode=OneWay}" />
                                    <Button
                                        x:Uid="CancelCaptureButton"
                                        AutomationProperties.AutomationId="CancelCapture"
                                        Command="{x:Bind ViewModel.CapturePositionCancelCommand}" />
                                </StackPanel>
                            </InfoBar>
                        </StackPanel>

                        <!-- Keyboard settings -->
                        <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.IsKeyboardTarget, Mode=OneWay}">
                            <controls:SettingsCard x:Uid="KeyCard">
                                <controls:SettingsCard.HeaderIcon>
                                    <FontIcon Glyph="&#xE765;" />
                                </controls:SettingsCard.HeaderIcon>
                                <StackPanel
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="12">
                                    <TextBlock
                                        AutomationProperties.AutomationId="KeyDisplay"
                                        VerticalAlignment="Center"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ViewModel.KeyDisplay, Mode=OneWay}" />
                                    <ToggleButton
                                        x:Uid="ArmKeyCapture"
                                        AutomationProperties.AutomationId="ArmKeyCapture"
                                        IsChecked="{x:Bind ViewModel.IsKeyCaptureArmed, Mode=TwoWay}" />
                                </StackPanel>
                            </controls:SettingsCard>
                            <TextBlock
                                x:Uid="KeyCaptureHint"
                                Margin="4,0,0,0"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Visibility="{x:Bind ViewModel.IsKeyCaptureArmed, Mode=OneWay}" />
                        </StackPanel>

                        <!-- Action -->
                        <controls:SettingsCard x:Uid="ActionCard">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE8EE;" />
                            </controls:SettingsCard.HeaderIcon>
                            <ComboBox
                                x:Uid="ModeSelector"
                                AutomationProperties.AutomationId="ModeSelector"
                                MinWidth="160"
                                DisplayMemberPath="DisplayName"
                                ItemsSource="{x:Bind ViewModel.Modes}"
                                SelectedItem="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}" />
                        </controls:SettingsCard>

                        <controls:SettingsCard x:Uid="IntervalCard" Visibility="{x:Bind ViewModel.IsRepeatMode, Mode=OneWay}">
                            <controls:SettingsCard.HeaderIcon>
                                <FontIcon Glyph="&#xE916;" />
                            </controls:SettingsCard.HeaderIcon>
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="12">
                                <NumberBox
                                    x:Uid="IntervalMs"
                                    AutomationProperties.AutomationId="IntervalMs"
                                    Maximum="10000"
                                    MinWidth="140"
                                    Minimum="10"
                                    SmallChange="10"
                                    SpinButtonPlacementMode="Compact"
                                    Value="{x:Bind ViewModel.IntervalMs, Mode=TwoWay}" />
                                <TextBlock
                                    AutomationProperties.AutomationId="CpsText"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind ViewModel.CpsText, Mode=OneWay}" />
                            </StackPanel>
                        </controls:SettingsCard>
                    </StackPanel>
                </ContentControl>

                <TextBlock
                    x:Uid="Hint"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
